FROM rust:1.85-bookworm

# Install zig, uv, maturin
RUN apt-get update && apt-get install -y python3 python3-pip python3-venv curl xz-utils && \
    curl -LsSf https://astral.sh/uv/install.sh | sh && \
    cargo install maturin && \
    curl -L https://ziglang.org/download/0.13.0/zig-linux-x86_64-0.13.0.tar.xz | tar -xJ -C /usr/local && \
    ln -s /usr/local/zig-linux-x86_64-0.13.0/zig /usr/local/bin/zig

ENV PATH="/root/.cargo/bin:/root/.local/bin:${PATH}"

WORKDIR /workspace
COPY . .

RUN cargo build --workspace
RUN cargo test --workspace
RUN uv sync && uv run python -c "import clang_tool_chain_bins"
